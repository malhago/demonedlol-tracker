# ─── Discord Bot ───────────────────────────────────────────────────────────────
# Token du bot (Discord Developer Portal > Bot > Token)
DISCORD_TOKEN=your-discord-bot-token-here

# Application ID du bot (Discord Developer Portal > General Information > Application ID)
CLIENT_ID=your-client-id-here

# ─── Riot API ───────────────────────────────────────────────────────────────────
# Clé API Riot Games (https://developer.riotgames.com/)
# Pour un bot permanent, demande une Production API Key
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Bot config ─────────────────────────────────────────────────────────────────
# Intervalle de polling en minutes (défaut: 3)
POLL_INTERVAL_MINUTES=3
